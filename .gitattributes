# Normalize line endings to LF on commit, checkout as LF everywhere
* text=auto eol=lf
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.tar binary
*.gz binary
